{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the PackRest main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/specs" },
        { "path": "$APPDATA/specs/**" }
      ]
    },
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.pack-solutions.com/*" },
        { "url": "https://*.pack-solutions.gravitee.cloud/*" },
        { "url": "https://gitlab.com/*" },
        { "url": "https://*.gitlab.com/*" },
        { "url": "https://api.github.com/*" },
        { "url": "https://*.githubusercontent.com/*" },
        { "url": "https://storage.googleapis.com/*" },
        { "url": "https://*.amazonaws.com/*" }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/*" },
        { "url": "https://*.githubusercontent.com/*" }
      ]
    }
  ]
}
